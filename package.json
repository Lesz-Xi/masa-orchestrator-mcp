{
  "name": "masa-orchestration",
  "version": "1.2.0",
  "private": true,
  "type": "module",
  "description": "Guardrail enforcement and delegation management MCP server for MASA",
  "scripts": {
    "agent:bootstrap": "node scripts/agent-bootstrap.mjs",
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "dev:http": "MCP_TRANSPORT=http tsx src/http.ts",
    "start:http": "MCP_TRANSPORT=http node dist/http.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "glob": "^10.4.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "vitest": "^4.0.18"
  }
}
